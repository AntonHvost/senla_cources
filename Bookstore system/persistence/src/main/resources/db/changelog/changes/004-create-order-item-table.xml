<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="4" author="bookstore-team">
        <comment>Создание таблицы позиций заказа</comment>

        <createTable tableName="order_item" schemaName="public">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" primaryKeyName="pk_order_item"/>
            </column>
            <column name="order_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_order_item_order"
                             references="&quot;order&quot;(id)" deleteCascade="true"/>
            </column>
            <column name="book_id" type="bigint">
                <constraints nullable="false" foreignKeyName="fk_order_item_book"
                             references="book(id)"/>
            </column>
            <column name="quantity" type="integer" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="order_item" indexName="idx_order_item_order_id">
            <column name="order_id"/>
        </createIndex>

        <createIndex tableName="order_item" indexName="idx_order_item_book_id">
            <column name="book_id"/>
        </createIndex>

        <!-- Уникальное ограничение: одна книга может быть в заказе только один раз -->
        <addUniqueConstraint tableName="order_item"
                             columnNames="order_id, book_id"
                             constraintName="uk_order_item_order_book"/>
    </changeSet>

</databaseChangeLog>